{
  "name": "@sveltia/i18n",
  "version": "1.0.0",
  "description": "An internationalization (i18n) library for Svelte applications that uses Unicode MessageFormat 2 (MF2) to format messages.",
  "keywords": [
    "svelte",
    "i18n",
    "internationalization",
    "l10n",
    "localization",
    "translation",
    "messageformat",
    "mf2"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sveltia/sveltia-i18n.git"
  },
  "license": "MIT",
  "author": {
    "name": "Kohei Yoshino",
    "url": "https://github.com/kyoshino"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.svelte.d.ts",
      "svelte": "./dist/index.svelte.js",
      "default": "./dist/index.svelte.js"
    }
  },
  "svelte": "./dist/index.svelte.js",
  "types": "./dist/index.svelte.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "svelte-kit sync && svelte-package",
    "build:watch": "svelte-kit sync && svelte-package --watch",
    "check": "pnpm run '/^check:.*/'",
    "check:audit": "pnpm audit",
    "check:cspell": "cspell --no-progress",
    "check:eslint": "eslint .",
    "check:oxlint": "oxlint .",
    "check:prettier": "prettier --check .",
    "check:stylelint": "stylelint '**/*.{css,scss,svelte}'",
    "check:svelte": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "dev": "vite dev",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "messageformat": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "cspell": "^9.8.0",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "oxlint": "^1.58.0",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "svelte-preprocess": "^6.0.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "yaml": "^2.8.3"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
